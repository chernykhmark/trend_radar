# --- Database ---
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/trend_radar
# Для psql (миграции вручную) — без драйвера:
# PSQL_URL=postgresql://user:pass@host:5432/trend_radar

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL_SCORE=gpt-4o-mini
OPENAI_MODEL_DIGEST=gpt-4o
# OPENAI_PRICE_PER_1K_INPUT=0.00015
# OPENAI_PRICE_PER_1K_OUTPUT=0.0006

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=123456789

# --- Runtime ---
TZ=Europe/Moscow
LOG_LEVEL=INFO

# --- Schedule (cron) ---
COLLECT_CRON=0 7 * * *
DIGEST_CRON=0 10 * * 1